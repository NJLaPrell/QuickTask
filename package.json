{
  "name": "quicktask-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "pnpm -r --if-present test && node --test scripts/test/**/*.test.mjs",
    "test:smoke": "node scripts/smoke-host-adapters.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:package-manager": "node scripts/check-package-manager-consistency.mjs",
    "clean": "pnpm -r clean",
    "package:vscode": "pnpm --filter quicktask-vscode package:vsix",
    "package:openclaw": "pnpm --filter @quicktask/core build && pnpm --filter quicktask-openclaw package:artifact",
    "package:release": "pnpm package:vscode && pnpm package:openclaw && node scripts/generate-release-integrity.mjs",
    "release:notes": "node scripts/generate-curated-release-notes.mjs",
    "release:validate-changesets": "node scripts/validate-changeset-format.mjs",
    "release:verify-local-artifacts": "node scripts/verify-release-assets.mjs --assets-dir artifacts",
    "release:check-baseline": "node scripts/check-release-version-baseline.mjs",
    "release:handoff": "node scripts/release-handoff.mjs",
    "changeset": "changeset",
    "release:prepare": "node scripts/release-prepare-readiness.mjs",
    "release:version": "changeset version",
    "release:docs-check": "node scripts/release-docs-check.mjs",
    "release:check-workflow-contracts": "node scripts/check-workflow-contracts.mjs",
    "tasks:check": "node scripts/tasks-check.mjs",
    "qt:check-contract-drift": "node scripts/check-qt-contract-drift.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tar": "^7.5.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
