{
  "name": "quicktask-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check && pnpm workspace-kit:check-profile && pnpm workspace-kit:drift-check",
    "test": "pnpm -r --if-present test && node --test scripts/test/**/*.test.mjs",
    "test:smoke": "node scripts/smoke-host-adapters.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:package-manager": "node scripts/check-package-manager-consistency.mjs",
    "check:support-matrix": "node scripts/check-support-matrix-consistency.mjs",
    "check:package-compliance": "node scripts/check-package-compliance.mjs",
    "clean": "pnpm -r clean",
    "package:vscode": "pnpm --filter @quicktask/core build && pnpm --filter quicktask-vscode package:vsix",
    "package:openclaw": "pnpm --filter @quicktask/core build && pnpm --filter quicktask-openclaw package:artifact",
    "package:release": "pnpm package:vscode && pnpm package:openclaw && node scripts/generate-release-integrity.mjs",
    "release:notes": "node scripts/generate-curated-release-notes.mjs",
    "release:check-notes-quality": "node scripts/validate-release-notes-quality.mjs",
    "release:validate-changesets": "node scripts/validate-changeset-format.mjs",
    "release:verify-local-artifacts": "node scripts/verify-release-assets.mjs --assets-dir artifacts",
    "release:test-artifact-journeys": "node scripts/run-artifact-user-journeys.mjs --assets-dir artifacts",
    "release:validate-host-installs": "node scripts/host-install-validate.mjs --assets-dir artifacts",
    "release:check-baseline": "node scripts/check-release-version-baseline.mjs",
    "release:handoff": "node scripts/release-handoff.mjs",
    "changeset": "changeset",
    "release:prepare": "node scripts/release-prepare-readiness.mjs",
    "release:version": "changeset version",
    "release:docs-check": "node scripts/release-docs-check.mjs",
    "release:check-workflow-contracts": "node scripts/check-workflow-contracts.mjs",
    "tasks:check": "node scripts/tasks-check.mjs",
    "tasks:check-templates": "node scripts/check-task-templates.mjs",
    "templates:eval": "node scripts/template-eval-harness.mjs --dataset docs/templates/eval-dataset.json",
    "workspace-kit:phase1:cold-start-check": "node scripts/workspace-kit-phase1-cold-start-check.mjs",
    "workspace-kit:check-profile": "pnpm --filter quicktask-workspace-kit build && node packages/workspace-kit/dist/cli.js check",
    "workspace-kit:drift-check": "pnpm --filter quicktask-workspace-kit build && node packages/workspace-kit/dist/cli.js drift-check",
    "workspace-kit:phase2:pilot-adoption-check": "node scripts/workspace-kit-phase2-pilot-adoption-check.mjs",
    "docs:check-links": "node scripts/check-doc-links.mjs",
    "phase:check": "node scripts/phase-exit-check.mjs",
    "qt:sandbox": "node scripts/qt-sandbox.mjs",
    "check:generated-artifacts": "node scripts/check-generated-artifacts-policy.mjs",
    "check:command-entrypoints": "node scripts/check-command-entrypoints.mjs",
    "qt:check-contract-drift": "node scripts/check-qt-contract-drift.mjs"
  },
  "devDependencies": {
    "@quicktask/core": "workspace:*",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tar": "^7.5.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
