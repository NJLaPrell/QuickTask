{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/workspace-kit-workflow-contract.schema.json",
  "title": "Workspace Kit Workflow Contract",
  "type": "object",
  "required": ["schemaVersion", "phases", "checks", "gates"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "order", "title", "requiredChecks", "allowedTransitions"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "order": {
            "type": "integer",
            "minimum": 0
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "requiredChecks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "allowedTransitions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "command"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "phaseId", "requiredCheckIds", "onFailure"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "phaseId": {
            "type": "string",
            "minLength": 1
          },
          "requiredCheckIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "onFailure": {
            "type": "string",
            "enum": ["block", "warn"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
